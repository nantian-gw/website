---
import '../styles/custom.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import { getLandingRouteMeta } from '../lib/landingRoutes';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  pathname?: string;
}
const pathname = Astro.props.pathname ?? Astro.url.pathname;
const routeMeta = getLandingRouteMeta(pathname);
const {
  title = 'Nantian Gateway - Lightweight Kubernetes Gateway API | Go + Rust',
  description = 'Open-source Kubernetes Gateway API implementation with split-plane architecture. Go control plane + Rust data plane for high performance and efficiency.',
  lang = routeMeta.lang,
} = Astro.props;
const canonical = routeMeta.canonicalUrl;
const selfHrefLang = lang === 'zh' ? 'zh-CN' : 'en';
const altLang = lang === 'en' ? 'zh-CN' : 'en';
const altUrl = routeMeta.alternateUrl;
const ogLocale = lang === 'en' ? 'en_US' : 'zh_CN';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  'name': 'Nantian Gateway',
  'url': 'https://nantian.dev/',
  'description': description,
  'inLanguage': lang === 'zh' ? 'zh' : 'en',
  'potentialAction': {
    '@type': 'SearchAction',
    'target': 'https://nantian.dev/{lang}/?search={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  'name': 'Nantian Gateway',
  'url': 'https://nantian.dev/',
  'logo': 'https://nantian.dev/logo.svg',
  'sameAs': [
    'https://github.com/nantian-gw/gateway'
  ]
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={selfHrefLang} href={canonical} />
    {altUrl && <link rel="alternate" hreflang={altLang} href={altUrl} />}
    <link rel="alternate" hreflang="x-default" href="https://nantian.dev/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Nantian Gateway" />
    <meta property="og:image" content="https://nantian.dev/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://nantian.dev/og-image.png" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    <slot name="head" />
  </head>
  <body class="bg-[var(--color-bg-base)] text-[var(--color-text-primary)] antialiased">
    <slot />
  </body>
</html>
