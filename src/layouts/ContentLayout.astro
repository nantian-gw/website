---
import LandingLayout from '../layouts/LandingLayout.astro';
import Navbar from '../components/landing/Navbar.astro';
import Footer from '../components/landing/Footer.astro';

export interface Props {
  lang?: 'en' | 'zh';
  title: string;
  description?: string;
  heading: string;
  intro?: string;
  canonical?: string;
}

const {
  lang = 'en',
  title,
  description,
  heading,
  intro,
  canonical,
} = Astro.props;
---

<LandingLayout lang={lang} title={title} description={description} canonical={canonical}>
  <Navbar lang={lang} />
  <main class="content-page">
    <div class="content-container">
      <header class="content-header">
        <h1 class="content-title">{heading}</h1>
        {intro && <p class="content-intro">{intro}</p>}
      </header>
      <div class="content-body">
        <slot />
      </div>
    </div>
  </main>
  <Footer lang={lang} />
</LandingLayout>

<style>
  .content-page {
    min-height: 60vh;
    padding: 8rem 1.5rem 4rem;
  }

  .content-container {
    max-width: 48rem;
    margin: 0 auto;
  }

  .content-header {
    margin-bottom: 2.5rem;
  }

  .content-title {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.15;
    background: var(--color-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin: 0 0 1rem;
  }

  .content-intro {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  .content-body :global(section) {
    margin-bottom: 2.25rem;
  }

  .content-body :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .content-body :global(p) {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  .content-body :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .content-body :global(li) {
    position: relative;
    padding-left: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .content-body :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 9999px;
    background: var(--color-accent);
  }

  .content-body :global(a) {
    color: var(--color-accent-light);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .content-body :global(a:hover) {
    border-bottom-color: var(--color-accent-light);
  }

  .content-body :global(.muted) {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
</style>
