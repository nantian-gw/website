---
import ContentLayout from '../layouts/ContentLayout.astro';
---

<ContentLayout
  lang="en"
  title="404 — Page Not Found — Nantian Gateway"
  description="The page you are looking for does not exist."
  heading="404 — Page Not Found"
  intro="The page you are looking for doesn't exist or has been moved."
>
  <div style="text-align: center; padding: 2rem 0;">
    <div id="search" class="not-found-search"></div>
    <nav class="not-found-nav">
      <a href="/" class="primary">Home</a>
      <a href="/getting-started/quick-start/">Quick Start</a>
      <a href="/faq/">FAQ</a>
    </nav>
  </div>
</ContentLayout>

<script is:inline>
  (async () => {
    try {
      const pf = await import('/pagefind/pagefind.js');
      pf.init();
      const container = document.getElementById('search');
      if (container) new pf.PagefindUI({ element: container });
    } catch {}
  })();
</script>
