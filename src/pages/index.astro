  <Navbar lang="en" pathname="/" />
  <Hero lang="en" />
  <HomeIntro lang="en" />
  <CodeExample lang="en" />
  <ArchitectureDiagram lang="en" />
  <Features lang="en" />
  <Comparison lang="en" />
  <UseCases lang="en" />
  <QuickStart lang="en" />
  <Footer lang="en" />
</LandingLayout>
