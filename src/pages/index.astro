---
import LandingLayout from '../layouts/LandingLayout.astro';
import Navbar from '../components/landing/Navbar.astro';
import Hero from '../components/landing/Hero.astro';
import HomeIntro from '../components/landing/HomeIntro.astro';
import Features from '../components/landing/Features.astro';
import ArchitectureDiagram from '../components/landing/ArchitectureDiagram.astro';
import CodeExample from '../components/landing/CodeExample.astro';
import Comparison from '../components/landing/Comparison.astro';
import UseCases from '../components/landing/UseCases.astro';
