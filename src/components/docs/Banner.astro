---
const locale = Astro.locals.starlightRoute.locale ?? 'en';
const isZh = locale === 'zh';
---

<div
  class="sl-banner"
  data-pagefind-ignore
  style="background: rgba(245,158,11,0.1); border-bottom: 1px solid rgba(245,158,11,0.2); color: #b45309; padding: 0.625rem 1rem; text-align: center; font-size: 0.8125rem; line-height: 1.5;"
>
  {isZh ? (
    <span>⚠️ <strong>警告：</strong>Nantian Gateway 目前仍处于开发阶段，<strong>不适用于生产环境</strong>。</span>
  ) : (
    <span>⚠️ <strong>WARNING:</strong> Nantian Gateway is currently in active development and <strong>NOT suitable for production use yet</strong>.</span>
  )}
</div>
