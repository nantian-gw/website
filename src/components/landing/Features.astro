---
import FeatureCard from './FeatureCard.astro';
import { landingCopy } from '../../i18n/landing';

export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;

const { sectionTitle, sectionSubtitle, features } = landingCopy[lang].features;
---

<section class="features" aria-label={sectionTitle}>
  <div class="features-container">
    <header class="features-header">
      <h2 class="features-heading gradient-text">{sectionTitle}</h2>
      <p class="features-subtitle">{sectionSubtitle}</p>
    </header>

    <div class="features-grid">
      {features.map((feature) => (
        <FeatureCard
          icon={feature.icon}
          title={feature.title}
          description={feature.description}
          href={feature.href}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--color-bg-base);
    padding: 5rem 1.5rem;
  }

  .features-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  .features-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .features-heading {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem;
  }

  .features-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .features {
      padding: 3rem 1rem;
    }

    .features-heading {
      font-size: 1.75rem;
    }

    .features-header {
      margin-bottom: 2rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
