  /* Layer 3 — close, fast, larger brighter stars (mixed white + cyan accent) */
  .starfield-layer--fast {
    --star-size: 3px;
    --anim-duration: 8s;
    animation: starDrift var(--anim-duration) linear infinite;
  }

  .starfield-layer--fast::before {
    content: '';
    position: absolute;
    width: var(--star-size);
    height: var(--star-size);
    border-radius: 50%;
    background: rgba(203, 213, 225, 0.8);
    box-shadow:
      12vw 10vh 0 0 rgba(203, 213, 225, 0.6),
      32vw 22vh 0 0 rgba(6, 182, 212, 0.5),
      52vw 8vh 0 0 rgba(203, 213, 225, 0.7),
      72vw 22vh 0 0 rgba(6, 182, 212, 0.4),
      88vw 10vh 0 0 rgba(203, 213, 225, 0.6),
      8vw 42vh 0 0 rgba(6, 182, 212, 0.5),
      28vw 48vh 0 0 rgba(203, 213, 225, 0.7),
      48vw 38vh 0 0 rgba(6, 182, 212, 0.4),
      68vw 48vh 0 0 rgba(203, 213, 225, 0.6),
