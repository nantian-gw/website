  .starfield-layer--fast::after {
    content: '';
    position: absolute;
    width: var(--star-size);
    height: var(--star-size);
    border-radius: 50%;
    background: rgba(203, 213, 225, 0.8);
    box-shadow:
      22vw 15vh 0 0 rgba(203, 213, 225, 0.5),
      42vw 25vh 0 0 rgba(6, 182, 212, 0.6),
      62vw 15vh 0 0 rgba(203, 213, 225, 0.4),
