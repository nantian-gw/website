      3vw 55vh 0 0 rgba(148, 163, 184, 0.5),
      15vw 62vh 0 0 rgba(148, 163, 184, 0.3),
      28vw 55vh 0 0 rgba(148, 163, 184, 0.6),
      38vw 68vh 0 0 rgba(148, 163, 184, 0.2),
      50vw 58vh 0 0 rgba(148, 163, 184, 0.4),
