    --star-size: 2px;
    --anim-duration: 12s;
    animation: starDrift var(--anim-duration) linear infinite;
  }

  .starfield-layer--medium::before,
  .starfield-layer--medium::after {
    content: '';
    position: absolute;
    width: var(--star-size);
    height: var(--star-size);
    border-radius: 50%;
    background: rgba(148, 163, 184, 0.7);
    box-shadow:
      8vw 5vh 0 0 rgba(148, 163, 184, 0.5),
