---
export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;

const isZh = lang === 'zh';

const heading = isZh ? 'Nantian Gateway — Kubernetes Gateway API 网关' : 'Nantian Gateway — Kubernetes Gateway API';
const subtitle = isZh
  ? 'Kubernetes Gateway API 控制面与 Rust 数据面'
  : 'Kubernetes Gateway API control plane with a Rust data plane';
const tagline = isZh
  ? '标准 Gateway API 路由 · Go 控制面 · gRPC/xDS · 实验性 AI 与 Wasm 扩展'
  : 'Standard Gateway API routing · Go control plane · gRPC/xDS · Experimental AI and Wasm extensions';
const quickStartLabel = isZh ? '快速开始' : 'Quick Start';
const quickStartHref = isZh
  ? '/zh/getting-started/quick-start/'
  : '/getting-started/quick-start/';
const githubHref = 'https://github.com/nantian-gw/gateway';
const comparisonHref = isZh ? '/zh/comparison/' : '/comparison/';
const faqHref = isZh ? '/zh/faq/' : '/faq/';
const useCasesHref = isZh ? '/zh/use-cases/' : '/use-cases/';
const comparisonLabel = isZh ? '功能对比' : 'Comparison';
const faqLabel = 'FAQ';
const useCasesLabel = isZh ? '使用场景' : 'Use Cases';
---

<section class="hero" aria-label={isZh ? '首页横幅' : 'Hero banner'}>
  <!-- Starfield layers -->
  <div class="starfield" aria-hidden="true">
    <div class="starfield-layer starfield-layer--slow"></div>
    <div class="starfield-layer starfield-layer--medium"></div>
    <div class="starfield-layer starfield-layer--fast"></div>
  </div>

  <!-- Content -->
  <div class="hero-content">
    <h1 class="hero-heading gradient-text">
      {heading}
    </h1>

    <p class="hero-subtitle">
      {subtitle}
    </p>

    <p class="hero-tagline">
      {tagline}
    </p>

    <div class="hero-actions">
      <a href={quickStartHref} class="btn btn-primary glow-hover">
        {quickStartLabel}
        <svg class="btn-arrow" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
        </svg>
      </a>

      <a href={githubHref} class="btn btn-secondary glow-hover" target="_blank" rel="noopener noreferrer">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z" />
        </svg>
        GitHub
        <svg class="btn-arrow" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 0 0 1.06 0l7.22-7.22v5.69a.75.75 0 0 0 1.5 0v-7.5a.75.75 0 0 0-.75-.75h-7.5a.75.75 0 0 0 0 1.5h5.69l-7.22 7.22a.75.75 0 0 0 0 1.06Z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>

    <!-- GitHub star badge -->
    <div class="github-badge">
      <span class="github-badge-star" aria-hidden="true">★</span>
      <span class="github-badge-text">GitHub</span>
    </div>

    <!-- Quick links to high-value pages -->
    <div class="hero-quick-links">
      <a href={comparisonHref} class="hero-quick-link">{comparisonLabel}</a>
      <span class="hero-quick-sep" aria-hidden="true">·</span>
      <a href={faqHref} class="hero-quick-link">{faqLabel}</a>
      <span class="hero-quick-sep" aria-hidden="true">·</span>
      <a href={useCasesHref} class="hero-quick-link">{useCasesLabel}</a>
    </div>
  </div>
</section>

<style>
