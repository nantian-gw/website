  @keyframes starDrift {
    0% {
      transform: translateY(0);
      opacity: 0.6;
    }
    25% {
      opacity: 0.9;
    }
    50% {
      transform: translateY(-2vh);
      opacity: 0.4;
    }
    75% {
      opacity: 0.8;
    }
    100% {
      transform: translateY(0);
      opacity: 0.6;
    }
  }

  /* ===== Content ===== */
  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 48rem;
    animation: contentReveal 0.8s ease-out;
  }

  @keyframes contentReveal {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-heading {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .hero-subtitle {
    margin: 1.25rem 0 0;
    font-size: clamp(1.125rem, 3vw, 1.5rem);
    color: var(--color-text-secondary);
    font-weight: 400;
    line-height: 1.5;
    max-width: 36rem;
  }

  .hero-tagline {
    margin: 1rem 0 0;
    font-size: clamp(0.8125rem, 2vw, 0.9375rem);
    color: var(--color-text-muted);
    font-weight: 400;
    letter-spacing: 0.02em;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  /* ===== Actions ===== */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.5;
    text-decoration: none;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--color-gradient);
    color: #fff;
  }

  .btn-primary:hover {
    box-shadow: 0 0 24px rgba(6, 182, 212, 0.3), 0 0 48px rgba(6, 182, 212, 0.1);
  }

  .btn-secondary {
    background: var(--color-bg-surface);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    border-color: var(--color-border-light);
    background: var(--color-bg-elevated);
  }

  .btn-arrow {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .btn:hover .btn-arrow {
    transform: translateX(2px);
  }

  .btn-secondary:hover .btn-arrow {
    transform: translate(2px, -2px);
  }

  .btn-icon {
    width: 1.125em;
    height: 1.125em;
    flex-shrink: 0;
  }

  /* ===== GitHub Badge ===== */
  .github-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 1.5rem;
    padding: 0.375rem 0.875rem;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    transition: border-color 0.25s ease;
  }

  .github-badge:hover {
    border-color: var(--color-border-light);
  }

  .github-badge-star {
    color: #f59e0b;
    font-size: 0.875rem;
    line-height: 1;
  }

  .github-badge-text {
    font-weight: 500;
  }

  /* ===== Quick Links ===== */
  .hero-quick-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-quick-link {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    font-weight: 500;
  }

  .hero-quick-link:hover {
    color: var(--color-accent-light);
  }

  .hero-quick-sep {
    color: var(--color-border);
    font-size: 0.875rem;
    user-select: none;
  }

  /* ===== Responsive ===== */
  @media (max-width: 640px) {
    .hero {
      padding: 4rem 1rem;
      min-height: 90vh;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
      max-width: 20rem;
    }

    .btn {
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .starfield-layer,
    .hero-content,
    .btn,
    .btn-arrow {
      animation: none !important;
      transition: none !important;
      transform: none !important;
    }

    .btn:hover .btn-arrow,
    .btn-secondary:hover .btn-arrow {
      transform: none !important;
    }
  }
