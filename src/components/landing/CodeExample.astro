---
export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const isZh = lang === 'zh';

const heading = isZh ? '5 分钟快速开始' : 'Quick Start in 5 Minutes';
const subtitle = isZh
  ? '一条 Helm 命令安装，一个 HTTPRoute 资源即可路由流量'
  : 'One Helm command to install, one HTTPRoute resource to route traffic';

const step1Label = isZh ? '① 安装网关' : '① Install the Gateway';
const step2Label = isZh ? '② 创建你的第一个路由' : '② Create Your First Route';
const docLinkText = isZh ? '📖 完整文档 →' : '📖 Full Documentation →';
const docLinkHref = isZh ? '/zh/getting-started/quick-start/' : '/getting-started/quick-start/';

const installCommands = [
  'helm repo add nantian-gw https://chart.nantian.dev',
  'helm repo update',
  'helm install nantian-gw nantian-gw/nantian-gw --namespace nantian-gw --create-namespace',
];

const routeYaml = `apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: my-app
spec:
  parentRefs:
  - name: nantian-gw
  rules:
  - matches:
    - path:
        type: PathPrefix
        value: /api
    backendRefs:
    - name: my-service
      port: 8080`;
---

<section class="code-example" aria-label={heading}>
  <div class="code-example-container">
    <header class="code-example-header">
      <h2 class="code-example-heading gradient-text">{heading}</h2>
      <p class="code-example-subtitle">{subtitle}</p>
    </header>

    <div class="code-example-grid">
      <div class="code-example-col">
        <h3 class="code-example-step-title">{step1Label}</h3>
        <div class="code-block">
          <div class="code-block-header">
            <div class="code-block-dots" aria-hidden="true">
              <span class="code-block-dot code-block-dot--red"></span>
              <span class="code-block-dot code-block-dot--yellow"></span>
              <span class="code-block-dot code-block-dot--green"></span>
            </div>
            <span class="code-block-label">Terminal</span>
          </div>
          <pre class="code-block-body"><code>{installCommands.map((cmd) => (
            <span class="code-block-line">
              <span class="code-block-prompt" aria-hidden="true">$ </span>
              <span class="code-block-text">{cmd}</span>
            </span>
          ))}</code></pre>
        </div>
      </div>

      <div class="code-example-col">
        <h3 class="code-example-step-title">{step2Label}</h3>
        <div class="code-block">
          <div class="code-block-header">
            <div class="code-block-dots" aria-hidden="true">
              <span class="code-block-dot code-block-dot--red"></span>
              <span class="code-block-dot code-block-dot--yellow"></span>
              <span class="code-block-dot code-block-dot--green"></span>
            </div>
            <span class="code-block-label">httproute.yaml</span>
          </div>
          <pre class="code-block-body"><code>{routeYaml.split('\n').map((line) => (
            <span class="code-block-line code-block-line--yaml">
              <span class="code-block-text">{line || ' '}</span>
            </span>
          ))}</code></pre>
        </div>
      </div>
    </div>

    <div class="code-example-footer">
      <a href={docLinkHref} class="code-example-link">{docLinkText}</a>
    </div>
  </div>
</section>

<style>
  .code-example {
    padding: 5rem 1.5rem;
    background: var(--color-bg-base);
  }

  .code-example-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  .code-example-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .code-example-heading {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .code-example-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .code-example-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .code-example-col {
    display: flex;
    flex-direction: column;
  }

  .code-example-step-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 0.75rem;
  }

  .code-block {
    background: var(--color-bg-code);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
    flex: 1;
  }

  .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--color-border);
  }

  .code-block-dots {
    display: flex;
    gap: 0.5rem;
  }

  .code-block-dot {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    display: block;
  }

  .code-block-dot--red { background: #ef4444; }
  .code-block-dot--yellow { background: #f59e0b; }
  .code-block-dot--green { background: #10b981; }

  .code-block-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--sl-font-mono, 'JetBrains Mono', monospace);
  }

  .code-block-body {
    margin: 0;
    padding: 1rem;
    overflow-x: auto;
    font-family: var(--sl-font-mono, 'JetBrains Mono', monospace);
    font-size: 0.8125rem;
    line-height: 1.7;
    background: transparent;
    border: none;
    border-radius: 0;
  }

  .code-block-body code {
    display: block;
    background: transparent;
    color: var(--color-text-primary);
    padding: 0;
  }

  .code-block-line {
    display: flex;
    align-items: center;
  }

  .code-block-prompt {
    color: var(--color-accent-light);
    margin-right: 0.5rem;
    user-select: none;
    flex-shrink: 0;
  }

  .code-block-text {
    color: var(--color-text-secondary);
  }

  .code-block-line--yaml .code-block-text {
    color: var(--color-text-secondary);
  }

  .code-example-footer {
    text-align: center;
  }

  .code-example-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent-light);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .code-example-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .code-example {
      padding: 3rem 1rem;
    }

    .code-example-heading {
      font-size: 1.5rem;
    }

    .code-example-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
