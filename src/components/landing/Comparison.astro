---
export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const isZh = lang === 'zh';

const heading = isZh ? '为什么选择 Nantian Gateway？' : 'Why Nantian Gateway?';
const subtitle = isZh
  ? '与主流 Gateway API 实现的对比'
  : 'How Nantian compares to other Gateway API implementations';

const detailLinkText = isZh ? '🔬 详细对比 →' : '🔬 Full Comparison →';
const detailLinkHref = isZh ? '/zh/comparison/' : '/comparison/';

const rows = isZh
  ? [
      { feature: '标准 Gateway API', nantian: '✅ v1.5.1', envoy: '✅', traefik: '✅', nginx: '✅' },
      { feature: '控制面语言', nantian: 'Go', envoy: 'Go', traefik: 'Go', nginx: 'Go' },
      { feature: '数据面语言', nantian: 'Rust 🦀', envoy: 'C++', traefik: 'Go', nginx: 'NGINX C' },
      { feature: 'AI 网关能力', nantian: '✅ 实验', envoy: '✅ (AI Gateway)', traefik: '❌', nginx: '❌' },
      { feature: 'Wasm 插件', nantian: '✅ 实验', envoy: '✅', traefik: '✅', nginx: '❌' },
      { feature: '内置 Helm Chart', nantian: '✅', envoy: '✅', traefik: '✅', nginx: '✅' },
      { feature: '开源协议', nantian: 'Apache 2.0', envoy: 'Apache 2.0', traefik: 'MIT', nginx: 'Apache 2.0' },
    ]
  : [
      { feature: 'Gateway API', nantian: '✅ v1.5.1', envoy: '✅', traefik: '✅', nginx: '✅' },
      { feature: 'Control Plane', nantian: 'Go', envoy: 'Go', traefik: 'Go', nginx: 'Go' },
      { feature: 'Data Plane', nantian: 'Rust 🦀', envoy: 'C++', traefik: 'Go', nginx: 'NGINX C' },
      { feature: 'AI Gateway', nantian: '✅ Experimental', envoy: '✅ (AI Gateway)', traefik: '❌', nginx: '❌' },
      { feature: 'Wasm Plugins', nantian: '✅ Experimental', envoy: '✅', traefik: '✅', nginx: '❌' },
      { feature: 'Helm Chart', nantian: '✅', envoy: '✅', traefik: '✅', nginx: '✅' },
      { feature: 'License', nantian: 'Apache 2.0', envoy: 'Apache 2.0', traefik: 'MIT', nginx: 'Apache 2.0' },
    ];

const summary = isZh
  ? 'Nantian 的核心差异：Rust 数据面带来内存安全和高并发性能，原生 AI Gateway 能力让你无需额外组件即可管理 LLM 提供商流量。'
  : 'Nantian\'s key differentiator: Rust data plane for memory safety and high concurrency, plus native AI Gateway capabilities to manage LLM provider traffic without extra components.';

const colHeaders = isZh
  ? ['特性', 'Nantian Gateway', 'Envoy Gateway', 'Traefik', 'NGINX Gateway']
  : ['Feature', 'Nantian Gateway', 'Envoy Gateway', 'Traefik', 'NGINX Gateway'];
---

<section class="comparison" aria-label={heading}>
  <div class="comparison-container">
    <header class="comparison-header">
      <h2 class="comparison-heading gradient-text">{heading}</h2>
      <p class="comparison-subtitle">{subtitle}</p>
    </header>

    <div class="comparison-table-wrapper">
      <table class="comparison-table">
        <thead>
          <tr>
            {colHeaders.map((h) => <th class="comparison-th">{h}</th>)}
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class="comparison-tr">
              <td class="comparison-td comparison-td--feature">{row.feature}</td>
              <td class="comparison-td comparison-td--nantian">{row.nantian}</td>
              <td class="comparison-td">{row.envoy}</td>
              <td class="comparison-td">{row.traefik}</td>
              <td class="comparison-td">{row.nginx}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="comparison-summary">{summary}</p>

    <div class="comparison-footer">
      <a href={detailLinkHref} class="comparison-link">{detailLinkText}</a>
    </div>
  </div>
</section>

<style>
  .comparison {
    padding: 5rem 1.5rem;
    background: var(--color-bg-base);
  }

  .comparison-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  .comparison-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .comparison-heading {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .comparison-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .comparison-table-wrapper {
    overflow-x: auto;
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .comparison-th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
  }

  .comparison-th:first-child {
    padding-left: 1.25rem;
  }

  .comparison-tr:not(:last-child) .comparison-td {
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .comparison-td {
    padding: 0.625rem 1rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .comparison-td:first-child {
    padding-left: 1.25rem;
  }

  .comparison-td--feature {
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .comparison-td--nantian {
    color: var(--color-accent-light);
    font-weight: 500;
  }

  .comparison-summary {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 1.5rem;
    text-align: center;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  .comparison-footer {
    text-align: center;
  }

  .comparison-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent-light);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .comparison-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .comparison {
      padding: 3rem 1rem;
    }

    .comparison-heading {
      font-size: 1.5rem;
    }

    .comparison-table {
      font-size: 0.8125rem;
    }

    .comparison-th,
    .comparison-td {
      padding: 0.5rem 0.75rem;
    }
  }
</style>
