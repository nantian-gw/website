---
import { landingCopy } from '../../i18n/landing';

export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;

const { heading, subtitle, detailLinkText, detailLinkHref, rows, summary, colHeaders } =
  landingCopy[lang].comparison;
---

<section class="comparison" aria-label={heading}>
  <div class="comparison-container">
    <header class="comparison-header">
      <h2 class="comparison-heading gradient-text">{heading}</h2>
      <p class="comparison-subtitle">{subtitle}</p>
    </header>

    <div class="comparison-table-wrapper">
      <table class="comparison-table">
        <thead>
          <tr>
            {colHeaders.map((h) => <th class="comparison-th">{h}</th>)}
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class="comparison-tr">
              <td class="comparison-td comparison-td--feature">{row.feature}</td>
              <td class="comparison-td comparison-td--nantian">{row.nantian}</td>
              <td class="comparison-td">{row.envoy}</td>
              <td class="comparison-td">{row.traefik}</td>
              <td class="comparison-td">{row.nginx}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="comparison-summary">{summary}</p>

    <div class="comparison-footer">
      <a href={detailLinkHref} class="comparison-link">{detailLinkText}</a>
    </div>
  </div>
</section>

<style>
  .comparison {
    padding: 5rem 1.5rem;
    background: var(--color-bg-base);
  }

  .comparison-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  .comparison-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .comparison-heading {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .comparison-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .comparison-table-wrapper {
    overflow-x: auto;
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .comparison-th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
  }

  .comparison-th:first-child {
    padding-left: 1.25rem;
  }

  .comparison-tr:not(:last-child) .comparison-td {
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .comparison-td {
    padding: 0.625rem 1rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .comparison-td:first-child {
    padding-left: 1.25rem;
  }

  .comparison-td--feature {
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .comparison-td--nantian {
    color: var(--color-accent-light);
    font-weight: 500;
  }

  .comparison-summary {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 1.5rem;
    text-align: center;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  .comparison-footer {
    text-align: center;
  }

  .comparison-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent-light);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .comparison-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .comparison {
      padding: 3rem 1rem;
    }

    .comparison-heading {
      font-size: 1.5rem;
    }

    .comparison-table {
      font-size: 0.8125rem;
    }

    .comparison-th,
    .comparison-td {
      padding: 0.5rem 0.75rem;
    }
  }
</style>
