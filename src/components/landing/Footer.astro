---
import { landingCopy } from '../../i18n/landing';

export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;

const {
  docsLabel,
  aboutLabel,
  contactLabel,
  privacyLabel,
  termsLabel,
  communityLabel,
  builtWith,
  docsHref,
  aboutHref,
  contactHref,
  privacyHref,
  termsHref,
  footerAria,
  footerLinksAria,
} = landingCopy[lang].footer;

const githubHref = 'https://github.com/nantian-gw/gateway';
const communityHref = 'https://github.com/nantian-gw/gateway/issues';
---

<footer class="footer" role="contentinfo" aria-label={footerAria}>
  <div class="footer-container">
    <!-- Left: Copyright + License -->
    <div class="footer-left">
      <p class="footer-copyright">&copy; 2026 Nantian Gateway</p>
      <span class="footer-divider" aria-hidden="true">&middot;</span>
      <p class="footer-license">Apache 2.0 License</p>
    </div>

    <!-- Center: Links -->
    <nav class="footer-links" aria-label={footerLinksAria}>
      <a href={docsHref} class="footer-link">{docsLabel}</a>
      <a href={aboutHref} class="footer-link">{aboutLabel}</a>
      <a href={contactHref} class="footer-link">{contactLabel}</a>
      <a href={privacyHref} class="footer-link">{privacyLabel}</a>
      <a href={termsHref} class="footer-link">{termsLabel}</a>
      <a href={githubHref} class="footer-link" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href={communityHref} class="footer-link" target="_blank" rel="noopener noreferrer">{communityLabel}</a>
    </nav>

    <!-- Right: Built with -->
    <div class="footer-right">
      <p class="footer-built-with">
        <span class="footer-built-text">{builtWith}</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-base);
    border-top: 1px solid var(--color-border);
    padding: 2.5rem 1.5rem;
    margin-top: 6rem;
  }

  .footer-container {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer-copyright,
  .footer-license {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .footer-divider {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1.5;
  }

  .footer-link:hover {
    color: var(--color-accent-light);
  }

  .footer-right {
    display: flex;
    align-items: center;
  }

  .footer-built-with {
    margin: 0;
  }

  .footer-built-text {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Responsive: stack on small screens */
  @media (max-width: 640px) {
    .footer-container {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1rem;
    }

    .footer-left {
      justify-content: center;
    }

    .footer-links {
      gap: 1.25rem;
    }
  }
</style>
