---
import { landingCopy } from '../../i18n/landing';

export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;

const {
  sectionTitle,
  sectionSubtitle,
  highlights,
  bottomCta,
  perfTitle,
  perfItems,
  communityTitle,
  communityItems,
} = landingCopy[lang].homeIntro;
---

<section class="home-intro" aria-label={sectionTitle}>
  <div class="home-intro-container">
    <header class="home-intro-header">
      <h2 class="home-intro-heading gradient-text">{sectionTitle}</h2>
      <p class="home-intro-subtitle">{sectionSubtitle}</p>
    </header>

    <div class="home-intro-grid">
      {highlights.map((item) => (
        <article class="home-intro-card">
          <h3 class="home-intro-card-title">{item.title}</h3>
          <p class="home-intro-card-desc">{item.desc}</p>
        </article>
      ))}
    </div>

    <div class="home-intro-stats">
      <div class="home-intro-stats-col">
        <h3 class="home-intro-stats-title">{perfTitle}</h3>
        <ul class="home-intro-stats-list">
          {perfItems.map((item) => (
            <li class="home-intro-stats-item">{item}</li>
          ))}
        </ul>
      </div>
      <div class="home-intro-stats-col">
        <h3 class="home-intro-stats-title">{communityTitle}</h3>
        <ul class="home-intro-stats-list">
          {communityItems.map((item) => (
            <li class="home-intro-stats-item">{item}</li>
          ))}
        </ul>
      </div>
    </div>

    <div class="home-intro-cta">
      <h3 class="home-intro-cta-title">{bottomCta.title}</h3>
      <p class="home-intro-cta-desc">{bottomCta.desc}</p>
      <a href={bottomCta.linkHref} class="home-intro-cta-link">
        {bottomCta.linkText}
      </a>
    </div>
  </div>
</section>

<style>
  .home-intro {
    padding: 5rem 1.5rem;
    background: var(--color-bg-base);
  }

  .home-intro-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  .home-intro-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .home-intro-heading {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .home-intro-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 36rem;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .home-intro-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .home-intro-card {
    background: var(--color-bg-card, rgba(255, 255, 255, 0.03));
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .home-intro-card:hover {
    border-color: var(--color-border-light);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .home-intro-card-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .home-intro-card-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .home-intro-cta {
    text-align: center;
    background: linear-gradient(135deg, rgba(6, 182, 212, 0.06), rgba(6, 182, 212, 0.02));
    border: 1px solid rgba(6, 182, 212, 0.15);
    border-radius: 0.75rem;
    padding: 2.5rem 2rem;
  }

  .home-intro-cta-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .home-intro-cta-desc {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  .home-intro-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 2rem;
    background: linear-gradient(135deg, #06b6d4, #0ea5e9);
    color: #fff;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .home-intro-cta-link:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  /* ===== Stats ===== */
  .home-intro-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .home-intro-stats-col {
    background: var(--color-bg-card, rgba(255, 255, 255, 0.03));
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .home-intro-stats-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 1rem;
    letter-spacing: -0.01em;
  }

  .home-intro-stats-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .home-intro-stats-item {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    padding-left: 1.25rem;
    position: relative;
  }

  .home-intro-stats-item::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-accent-light, #06b6d4);
    font-size: 0.75rem;
    top: 0.15rem;
  }

  @media (max-width: 768px) {
    .home-intro {
      padding: 3rem 1rem;
    }

    .home-intro-heading {
      font-size: 1.5rem;
    }

    .home-intro-grid {
      grid-template-columns: 1fr;
    }

    .home-intro-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
