---
export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const isZh = lang === 'zh';

const heading = isZh ? '使用场景' : 'Use Cases';
const subtitle = isZh
  ? '从 Kubernetes Ingress 到 AI 网关，一个平台覆盖所有需求'
  : 'From Kubernetes Ingress to AI Gateway — one platform for every scenario';

const linkText = isZh ? '🎯 更多场景 →' : '🎯 More Use Cases →';
const linkHref = isZh ? '/zh/use-cases/' : '/use-cases/';

const cases = isZh
  ? [
      {
        icon: '🚪',
        title: 'Kubernetes Ingress 入口',
        desc: '标准 Gateway API 兼容，NGINX Ingress 迁移友好。支持 HTTP、gRPC、TCP、UDP、TLS 全协议路由，无需自定义 CRD。',
      },
      {
        icon: '🤖',
        title: 'AI API 网关',
        desc: '内置 AIService 与 TokenPolicy 资源，统一管理 OpenAI、Anthropic、混元等多模型提供商的认证、限流和路由。',
      },
      {
        icon: '🔌',
        title: 'Wasm 边缘扩展',
        desc: '通过 WasmPlugin 在数据面注入自定义逻辑——请求改写、认证、观测——无需重启网关进程即可热加载。',
      },
      {
        icon: '📊',
        title: '多集群流量管理',
        desc: 'gRPC/xDS 协议分发路由快照，控制面与数据面解耦，支持多集群联邦部署与独立扩缩容。',
      },
    ]
  : [
      {
        icon: '🚪',
        title: 'Kubernetes Ingress',
        desc: 'Standard Gateway API compatible, suitable for NGINX Ingress migration. Supports HTTP, gRPC, TCP, UDP, and TLS routing — no custom CRDs required.',
      },
      {
        icon: '🤖',
        title: 'AI API Gateway',
        desc: 'Built-in AIService and TokenPolicy resources unify authentication, rate limiting, and routing across OpenAI, Anthropic, Hunyuan, and other model providers.',
      },
      {
        icon: '🔌',
        title: 'Wasm Edge Extensions',
        desc: 'Inject custom logic into the data plane via WasmPlugin — request rewriting, authentication, observability — hot-loadable without restarting the gateway.',
      },
      {
        icon: '📊',
        title: 'Multi-Cluster Traffic',
        desc: 'gRPC/xDS protocol distributes routing snapshots. Decoupled control and data planes enable multi-cluster federation with independent scaling.',
      },
    ];
---

<section class="use-cases" aria-label={heading}>
  <div class="use-cases-container">
    <header class="use-cases-header">
      <h2 class="use-cases-heading gradient-text">{heading}</h2>
      <p class="use-cases-subtitle">{subtitle}</p>
    </header>

    <div class="use-cases-grid">
      {cases.map((c) => (
        <article class="use-cases-card">
          <span class="use-cases-icon" aria-hidden="true">{c.icon}</span>
          <div class="use-cases-content">
            <h3 class="use-cases-title">{c.title}</h3>
            <p class="use-cases-desc">{c.desc}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="use-cases-footer">
      <a href={linkHref} class="use-cases-link">{linkText}</a>
    </div>
  </div>
</section>

<style>
  .use-cases {
    padding: 5rem 1.5rem;
    background: var(--color-bg-base);
  }

  .use-cases-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  .use-cases-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .use-cases-heading {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .use-cases-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .use-cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .use-cases-card {
    background: var(--color-bg-card, rgba(255, 255, 255, 0.03));
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    display: flex;
    gap: 1rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .use-cases-card:hover {
    border-color: var(--color-border-light);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .use-cases-icon {
    font-size: 1.75rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .use-cases-content {
    flex: 1;
    min-width: 0;
  }

  .use-cases-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 0.375rem;
    letter-spacing: -0.01em;
  }

  .use-cases-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  .use-cases-footer {
    text-align: center;
  }

  .use-cases-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent-light);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .use-cases-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .use-cases {
      padding: 3rem 1rem;
    }

    .use-cases-heading {
      font-size: 1.5rem;
    }

    .use-cases-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
