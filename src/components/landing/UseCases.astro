---
import { landingCopy } from '../../i18n/landing';

export interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;

const { heading, subtitle, linkText, linkHref, cases } = landingCopy[lang].useCases;
---

<section class="use-cases" aria-label={heading}>
  <div class="use-cases-container">
    <header class="use-cases-header">
      <h2 class="use-cases-heading gradient-text">{heading}</h2>
      <p class="use-cases-subtitle">{subtitle}</p>
    </header>

    <div class="use-cases-grid">
      {cases.map((c) => (
        <article class="use-cases-card">
          <span class="use-cases-icon" aria-hidden="true">{c.icon}</span>
          <div class="use-cases-content">
            <h3 class="use-cases-title">{c.title}</h3>
            <p class="use-cases-desc">{c.desc}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="use-cases-footer">
      <a href={linkHref} class="use-cases-link">{linkText}</a>
    </div>
  </div>
</section>

<style>
  .use-cases {
    padding: 5rem 1.5rem;
    background: var(--color-bg-base);
  }

  .use-cases-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  .use-cases-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .use-cases-heading {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .use-cases-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .use-cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .use-cases-card {
    background: var(--color-bg-card, rgba(255, 255, 255, 0.03));
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    display: flex;
    gap: 1rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .use-cases-card:hover {
    border-color: var(--color-border-light);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .use-cases-icon {
    font-size: 1.75rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .use-cases-content {
    flex: 1;
    min-width: 0;
  }

  .use-cases-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 0.375rem;
    letter-spacing: -0.01em;
  }

  .use-cases-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  .use-cases-footer {
    text-align: center;
  }

  .use-cases-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent-light);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .use-cases-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .use-cases {
      padding: 3rem 1rem;
    }

    .use-cases-heading {
      font-size: 1.5rem;
    }

    .use-cases-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
