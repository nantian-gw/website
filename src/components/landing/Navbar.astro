---
import { getLandingRouteMeta } from '../../lib/landingRoutes';

interface Props {
  lang?: 'en' | 'zh';
  pathname?: string;
}

const { lang = 'en', pathname = lang === 'zh' ? '/zh/' : '/' } = Astro.props;
const routeMeta = getLandingRouteMeta(pathname);
const homeHref = routeMeta.homePath;

const t = {
  docs: lang === 'zh' ? '文档' : 'Docs',
  github: 'GitHub',
  switchLang: lang === 'zh' ? 'EN' : '中文',
  switchHref: routeMeta.alternatePath ?? (lang === 'zh' ? '/' : '/zh/'),
};

const docsHref = `/${lang}/concepts/`;
const githubHref = 'https://github.com/nantian-gw/gateway';
---

<header
  id="landing-navbar"
  class="navbar fixed top-0 left-0 right-0 z-50 transition-all duration-300 ease-out h-16 flex items-center"
>
  <nav
    class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 flex items-center justify-between h-full"
  >
    <!-- Left: Logo + Brand -->
    <a
      href={homeHref}
      class="inline-flex items-center gap-2.5 group shrink-0"
      aria-label="Nantian Gateway home"
    >
      <img
        src="/logo.svg"
        alt="Nantian Gateway logo"
        class="h-8 w-8 transition-transform duration-300 group-hover:scale-110"
      />
      <span
        class="gradient-text text-xl font-bold tracking-tight hidden sm:inline"
      >
        Nantian
      </span>
    </a>

    <!-- Right: Nav links + Language switcher (desktop) -->
    <div class="hidden md:flex items-center gap-1">
      <!-- Docs -->
      <a
        href={docsHref}
        class="nav-link px-3 py-2 rounded-lg text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors duration-200"
      >
        {t.docs}
      </a>

      <!-- GitHub -->
      <a
        href={githubHref}
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link px-3 py-2 rounded-lg text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors duration-200"
      >
        <span class="flex items-center gap-1.5">
          <!-- GitHub icon -->
          <svg
            class="h-4 w-4 shrink-0"
            width="16" height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
            />
          </svg>
          {t.github}
        </span>
      </a>

      <!-- Separator -->
      <div class="h-5 w-px bg-[var(--color-border)] mx-1.5" aria-hidden="true"></div>

      <!-- Language Switcher -->
      <a
        href={t.switchHref}
        class="nav-link px-3 py-2 rounded-lg text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors duration-200 flex items-center gap-1.5"
        aria-label={`Switch language to ${t.switchLang}`}
      >
        <!-- Globe icon -->
        <svg
          class="h-4 w-4 shrink-0" width="16" height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" />
          <line x1="2" y1="12" x2="22" y2="12" />
          <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" />
        </svg>
        {t.switchLang}
      </a>
    </div>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden p-2 rounded-lg text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-surface)] transition-colors"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <svg
        id="menu-icon-open"
        class="h-6 w-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg
        id="menu-icon-close"
        class="h-6 w-6 hidden"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="mobile-menu absolute top-full left-0 right-0 overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0 invisible"
  >
    <div class="bg-[var(--color-bg-base)]/95 backdrop-blur-xl border-b border-[var(--color-border)] px-4 py-4 flex flex-col gap-1 md:hidden">
      <a
        href={docsHref}
        class="mobile-nav-link flex items-center px-3 py-2.5 rounded-lg text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-surface)] transition-colors"
      >
        {t.docs}
      </a>

      <a
        href={githubHref}
        target="_blank"
        rel="noopener noreferrer"
        class="mobile-nav-link flex items-center gap-1.5 px-3 py-2.5 rounded-lg text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-surface)] transition-colors"
      >
        <svg
          class="h-4 w-4 shrink-0" width="16" height="16"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
          />
        </svg>
        {t.github}
      </a>

      <div class="h-px bg-[var(--color-border)] my-1" aria-hidden="true"></div>

      <a
        href={t.switchHref}
        class="mobile-nav-link flex items-center gap-1.5 px-3 py-2.5 rounded-lg text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-surface)] transition-colors"
      >
        <svg
          class="h-4 w-4 shrink-0" width="16" height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" />
          <line x1="2" y1="12" x2="22" y2="12" />
          <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" />
        </svg>
        {t.switchLang}
      </a>
    </div>
  </div>
</header>

<style>
  /* Base navbar state — transparent */
  .navbar {
    background: transparent;
  }

  /* Scrolled state — dark glass */
  .navbar.scrolled {
    background: rgba(10, 14, 23, 0.9);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
  }

  /* Mobile menu open state */
  .mobile-menu.open {
    max-height: 400px;
    opacity: 1;
    visibility: visible;
  }
</style>

<script>
  // ── Scroll detection ──
  const navbar = document.getElementById('landing-navbar')!;

  function updateNavbarScroll() {
    if (window.scrollY > 10) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  }

  // Initial check
  updateNavbarScroll();
  window.addEventListener('scroll', updateNavbarScroll, { passive: true });

  // ── Mobile menu toggle ──
  const menuToggle = document.getElementById('mobile-menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const menuIconOpen = document.getElementById('menu-icon-open')!;
  const menuIconClose = document.getElementById('menu-icon-close')!;
  const mobileNavLinks = mobileMenu.querySelectorAll('.mobile-nav-link');

  let isMenuOpen = false;

  function openMenu() {
    isMenuOpen = true;
    mobileMenu.classList.add('open');
    menuIconOpen.classList.add('hidden');
    menuIconClose.classList.remove('hidden');
    menuToggle.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    isMenuOpen = false;
    mobileMenu.classList.remove('open');
    menuIconOpen.classList.remove('hidden');
    menuIconClose.classList.add('hidden');
    menuToggle.setAttribute('aria-expanded', 'false');
  }

  menuToggle.addEventListener('click', () => {
    if (isMenuOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  // Close menu when a link is clicked
  mobileNavLinks.forEach((link) => {
    link.addEventListener('click', () => {
      closeMenu();
    });
  });

  // Close menu on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isMenuOpen) {
      closeMenu();
      menuToggle.focus();
    }
  });
</script>
