{
  "name": "nantian-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "audit:ci": "node ./scripts/check-npm-audit.mjs",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run setup:browser && astro build && npm run build:llms && npm run build:markdown",
    "build:ci": "npm run setup:browser:ci && npm run build:astro && npm run build:llms && npm run build:markdown",
    "build:astro": "astro build",
    "build:llms": "node scripts/generate-llms-txt.mjs",
    "build:markdown": "node scripts/generate-markdown-content.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "npm run lint:js && npm run lint:md && astro check",
    "lint:js": "eslint .",
    "lint:md": "markdownlint-cli2 'src/content/docs/**/*.mdx' 'src/pages/**/*.astro' 'README.md'",
    "setup:browser": "npx playwright install chromium",
    "setup:browser:ci": "npx playwright install --with-deps chromium",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.40.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.8",
    "astro-pagefind": "^2.0.0",
    "rehype-mermaid": "^3.0.0",
    "sharp": "^0.35.2",
    "starlight-versions": "^0.9.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "markdownlint-cli2": "^0.22.1",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3"
  }
}
